{
  "name": "wakatime-sync",
  "version": "1.6.0",
  "description": "WakaTime plugin for OpenCode and Claude Code, automatically tracking time spent coding.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "license": "MIT",
  "author": "intisy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/intisy-ai/wakatime-sync.git"
  },
  "keywords": [
    "opencode",
    "claude",
    "wakatime",
    "plugin",
    "time",
    "tracking"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
